# App Settings
APP_NAME=Ads Manager
APP_VERSION=1.0.0
DEBUG=True

# API Security - Generiere mit: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=your-secret-api-key-here

# Database
DATABASE_URL=sqlite:///./ads_manager.db

# Google Ads - Hol dir diese Werte von:
# https://developers.google.com/google-ads/api/docs/first-call/overview
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# Meta Ads - Hol dir diese Werte von:
# https://developers.facebook.com/apps/
# META_APP_ID=
# META_APP_SECRET=
# META_ACCESS_TOKEN=
